# OpenAI API key (required for Use Case Finder "Generate analysis")
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: model for analysis (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Session secret for GT SSO (required in production)
SESSION_SECRET=your-random-secret-at-least-32-characters

# App URL for CAS callback (must match URL registered with Georgia Tech OIT)
# Development: http://localhost:8080
# Production: https://your-portal.gatech.edu
APP_URL=http://localhost:8080

# Optional: bypass real CAS in development
# CAS_DEV_MODE=true
# CAS_DEV_USER=gt123abc

# Course updater: search for LinkedIn Learning courses (optional)
# Without these, `pnpm run update-courses` uses built-in seed data.
# SERPAPI_KEY=   # https://serpapi.com/ - for Google search
# BING_SEARCH_KEY=   # https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
